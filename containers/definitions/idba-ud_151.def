Bootstrap: docker
From: ubuntu:22.04

%labels
    Maintainer lowry-nitrogen-team
    Version 1.2-idbaud-151bp
    Description IDBA-UD patched for 151bp max read length

%environment
    export LC_ALL=C
    export PATH=/usr/local/bin:$PATH

%post
    # 1. Install build dependencies
    apt-get update -y
    apt-get install -y --no-install-recommends \
        build-essential \
        autoconf \
        automake \
        libtool \
        wget \
        ca-certificates \
        zlib1g-dev

    # 2. Download IDBA-UD source
    cd /tmp
    wget https://github.com/loneknightpy/idba/archive/refs/tags/1.1.3.tar.gz
    tar -xf 1.1.3.tar.gz
    cd idba-1.1.3

    # 3. THE PATCH: Update the header for 151bp reads
    # Using quotes around the sed command to prevent shell interference
    sed -i 's/static const uint32_t kMaxShortSequence = 128;/static const uint32_t kMaxShortSequence = 151;/' src/sequence/short_sequence.h
    
    echo "Verifying patch in short_sequence.h:"
    grep "kMaxShortSequence =" src/sequence/short_sequence.h

    # 4. Generate build files and Compile
    # 'autoreconf -i' replaces the need for a specific autogen.sh script
    autoreconf -i
    ./configure
    make
    
# 5. Move binaries to system path
    cd /tmp/idba-1.1.3/bin
    
    # This will copy only the files that actually exist
    # idba_ud and fq2fa are the ones you definitely need
    cp idba_ud fq2fa idba /usr/local/bin/ || true
    
    # Optional: If you want to be extra safe and grab everything in bin:
    # cp * /usr/local/bin/
    
    # Ensure they are executable
    chmod +x /usr/local/bin/idba_ud /usr/local/bin/fq2fa

    
    # 6. Cleanup
    cd /
    rm -rf /tmp/idba-1.1.3 /tmp/1.1.3.tar.gz
    apt-get clean

%runscript
    echo "IDBA-UD (Custom Build: Max Read Length 151bp)"
    echo "------------------------------------------------"
    exec "$@"

%help
    IDBA-UD container patched specifically for 151bp reads.
    
    Key Step: 
    Before running idba_ud, you MUST merge your paired-end fastq files:
    singularity exec idba_ud_151.sif fq2fa --merge --filter R1.fq R2.fq merged.fa
    
    Then run the assembly:
    singularity exec idba_ud_151.sif idba_ud -r merged.fa -o output_dir